# -- Required ---------------------------------------------------------------
# Database connection -- hostname MUST be 'postgres' (the compose service name),
# NOT 'localhost'. Localhost won't work inside docker-compose networking.
DATABASE_URL=postgres://website:CHANGEME@postgres:5432/website_prod?sslmode=disable

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$12$CHANGEME_run_make_hash-password_PW=yourpassword

# -- Optional (defaults shown) ----------------------------------------------
PORT=8080
APP_ENV=production
ADMIN_HOST=admin.jared-wallace.com
SESSION_SECRET=generate-a-random-32-char-string-here
API_TOKEN=generate-a-random-token-for-api-push
IMAGE_DIR=/var/www/html/images

# -- Postgres sidecar (used by docker-compose.yml) --------------------------
POSTGRES_USER=website
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=website_prod
